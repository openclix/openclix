{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".build",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@templates/*": ["templates/*"]
    }
  },
  "include": ["templates/**/*.ts", "__tests__/**/*.ts"]
}
